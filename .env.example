# Porto onde o servidor Express vai correr (padrão: 3000)
PORT=3000

# Chave secreta de API para autenticar o scraper manual (POST /api/scrape/trigger)
# Altere para um valor seguro localmente e em produção
SCRAPE_API_KEY=minha-chave-secreta-local

# Caminho da base de dados SQLite (Opcional)
# Em desenvolvimento local, se não definido, cria 'server/omie_prices.db'
# DB_PATH=./server/omie_prices.db
